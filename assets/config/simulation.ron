// Default Simulation Configuration for emergent-sim
// Defines world size, agent count, resource density, and decay rates
// Used during Phase 2 (Simulation Core)

(
    world_size: (100.0, 100.0),
    initial_agent_count: 20,
    initial_resource_count: 6,
    needs_decay_rates: (
        hunger_per_sec: 0.02,
        fatigue_per_sec: 0.015,
        energy_per_sec: 0.01,
    ),
    spatial_grid_cell_size: 10.0,
    seed: 42,
    global_decay_multiplier: 1.0,
    global_regen_multiplier: 1.0,
    agent_move_speed: 4.0,
    random_walk_turn_secs: 1.25,
    agent_collider_radius: 0.45,
    agent_visual_height: 0.9,
)
